{
  "openapi": "3.0.0",
  "info": {
    "title": "Flora Bouquets API",
    "version": "1.0.0",
    "description": "REST API for Flora bouquets collection"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Bouquets",
      "description": "Operations with bouquets"
    }
  ],
  "paths": {
    "/api/bouquets": {
      "get": {
        "summary": "Get all bouquets",
        "tags": ["Bouquets"],
        "responses": {
          "200": {
            "description": "List of bouquets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bouquet"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new bouquet",
        "tags": ["Bouquets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bouquet created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}": {
      "get": {
        "summary": "Get bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Not found"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bouquet updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error or empty request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Not found"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Bouquet deleted successfully"
                    },
                    "bouquet": {
                      "$ref": "#/components/schemas/Bouquet"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Not found"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}/favorite": {
      "patch": {
        "summary": "Update bouquet favorite status",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FavoriteUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Not found"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}/photo": {
      "patch": {
        "summary": "Update bouquet photo",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": {
                    "type": "string",
                    "format": "binary",
                    "description": "Bouquet photo file"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photo updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Photo file is required or invalid file type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Photo file is required"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "BouquetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Bouquet id",
        "schema": {
          "type": "integer",
          "example": 1
        }
      }
    },
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Spring Elegance"
          },
          "description": {
            "type": "string",
            "example": "A delicate bouquet with pink and white spring flowers."
          },
          "price": {
            "type": "number",
            "example": 35
          },
          "favorite": {
            "type": "boolean",
            "example": false
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/bouquet.jpg"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-07T10:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-07T10:00:00.000Z"
          }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "example": "Spring Elegance"
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000,
            "example": "A delicate bouquet with pink and white spring flowers."
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "example": 35
          },
          "favorite": {
            "type": "boolean",
            "example": false
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/bouquet.jpg"
          }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "example": "Updated Bouquet"
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000,
            "example": "Updated bouquet description."
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "example": 45
          },
          "favorite": {
            "type": "boolean",
            "example": true
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/updated-bouquet.jpg"
          }
        }
      },
      "FavoriteUpdate": {
        "type": "object",
        "required": ["favorite"],
        "properties": {
          "favorite": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Not found"
          }
        }
      }
    }
  }
}