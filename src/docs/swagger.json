{
  "openapi": "3.0.0",
  "info": {
    "title": "Flora API",
    "version": "1.0.0",
    "description": "REST API for Flora bouquets, feedbacks and orders"
  },
  "servers": [
    {
      "url": "https://flora-backend-jtb2.onrender.com",
      "description": "Render production server"
    },
    {
      "url": "http://localhost:3001",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Bouquets",
      "description": "Operations with bouquets"
    },
    {
      "name": "Feedbacks",
      "description": "Operations with feedbacks"
    },
    {
      "name": "Orders",
      "description": "Operations with orders"
    }
  ],
  "paths": {
    "/api/bouquets": {
      "get": {
        "summary": "Get all bouquets",
        "tags": ["Bouquets"],
        "responses": {
          "200": {
            "description": "List of bouquets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bouquet"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new bouquet",
        "tags": ["Bouquets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bouquet created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}": {
      "get": {
        "summary": "Get bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bouquet updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete bouquet by id",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteBouquetResponse"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}/favorite": {
      "patch": {
        "summary": "Update bouquet favorite status",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FavoriteUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}/photo": {
      "patch": {
        "summary": "Update bouquet photo",
        "tags": ["Bouquets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photo updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Photo file is required or invalid file type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/feedbacks": {
      "get": {
        "summary": "Get all feedbacks",
        "tags": ["Feedbacks"],
        "responses": {
          "200": {
            "description": "List of feedbacks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feedback"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new feedback",
        "tags": ["Feedbacks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feedback created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feedback"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "get": {
        "summary": "Get all orders",
        "tags": ["Orders"],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new order",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "BouquetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Bouquet id",
        "schema": {
          "type": "integer",
          "example": 1
        }
      }
    },
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Spring Elegance"
          },
          "description": {
            "type": "string",
            "example": "A delicate bouquet with fresh spring flowers."
          },
          "price": {
            "type": "number",
            "example": 35
          },
          "favorite": {
            "type": "boolean",
            "example": true
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/bouquet.jpg"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Spring Elegance"
          },
          "description": {
            "type": "string",
            "example": "A delicate bouquet with fresh spring flowers."
          },
          "price": {
            "type": "number",
            "example": 35
          },
          "favorite": {
            "type": "boolean",
            "example": false
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/bouquet.jpg"
          }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "title": {
            "type": "string",
            "example": "Updated Bouquet"
          },
          "description": {
            "type": "string",
            "example": "Updated bouquet description."
          },
          "price": {
            "type": "number",
            "example": 45
          },
          "favorite": {
            "type": "boolean",
            "example": true
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/photos/updated-bouquet.jpg"
          }
        }
      },
      "FavoriteUpdate": {
        "type": "object",
        "required": ["favorite"],
        "properties": {
          "favorite": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "DeleteBouquetResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Bouquet deleted successfully"
          },
          "bouquet": {
            "$ref": "#/components/schemas/Bouquet"
          }
        }
      },
      "Feedback": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "text": {
            "type": "string",
            "example": "Flora made my anniversary unforgettable with their beautiful arrangement!"
          },
          "author": {
            "type": "string",
            "example": "Emma T."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FeedbackCreate": {
        "type": "object",
        "required": ["text", "author"],
        "properties": {
          "text": {
            "type": "string",
            "example": "Amazing flowers and fast delivery!"
          },
          "author": {
            "type": "string",
            "example": "Anna K."
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "productId": {
            "type": "integer",
            "example": 1
          },
          "productTitle": {
            "type": "string",
            "example": "Spring Elegance"
          },
          "quantity": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Test User"
          },
          "phone": {
            "type": "string",
            "example": "+15551234567"
          },
          "address": {
            "type": "string",
            "example": "456 Floral Ave, Sydney NSW 2000 AU"
          },
          "message": {
            "type": "string",
            "example": "Please deliver in the morning."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderCreate": {
        "type": "object",
        "required": [
          "productId",
          "productTitle",
          "quantity",
          "name",
          "phone",
          "address"
        ],
        "properties": {
          "productId": {
            "type": "integer",
            "example": 1
          },
          "productTitle": {
            "type": "string",
            "example": "Spring Elegance"
          },
          "quantity": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Test User"
          },
          "phone": {
            "type": "string",
            "example": "+15551234567"
          },
          "address": {
            "type": "string",
            "example": "456 Floral Ave, Sydney NSW 2000 AU"
          },
          "message": {
            "type": "string",
            "example": "Test order from Swagger"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Not found"
          }
        }
      }
    }
  }
}